{
  "name": "harvest-hub",
  "version": "1.0.0",
  "description": "Adaptive product scraping platform with premium dashboard and exports",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "license": "MIT",
  "bin": {
    "harvest": "./dist/src/cli/index.js",
    "harvesthub": "./dist/src/cli/index.js"
  },
  "files": [
    "dist/",
    "engine/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "scraper",
    "web-scraping",
    "e-commerce",
    "price-tracking",
    "product-data",
    "price-monitoring",
    "xlsx-export",
    "anti-bot",
    "scrapling"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/SufficientDaikon/harvesthub"
  },
  "homepage": "https://sufficientdaikon.github.io/harvesthub/",
  "bugs": {
    "url": "https://github.com/SufficientDaikon/harvesthub/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/src/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "tsc --noEmit",
    "harvest": "tsx src/cli/index.ts",
    "dashboard": "cd dashboard && npm run dev",
    "setup": "npm install && pip install -r engine/requirements.txt",
    "migrate": "tsx scripts/migrate-legacy.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.1.0",
    "croner": "^8.0.0",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "multer": "^2.1.1",
    "nanoid": "^5.0.7",
    "nodemailer": "^8.0.1",
    "ora": "^8.0.1",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "ws": "^8.16.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.0",
    "@types/nodemailer": "^7.0.11",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^1.6.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
